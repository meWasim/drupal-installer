#!/usr/bin/env php
<?php

$autoloadFiles = [
    __DIR__ . '/../vendor/autoload.php',      
    __DIR__ . '/../../../autoload.php',       
];

foreach ($autoloadFiles as $autoload) {
    if (file_exists($autoload)) {
        require $autoload;
        break;
    }
}

use Alfwasim\DrupalInstaller\Installer;

Installer::run($argv);